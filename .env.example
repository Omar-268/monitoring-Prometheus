# ─────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
#   cp .env.example .env
# Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────


# ── Email / Alertmanager ──────────────────────────────────────
# Gmail App Password (16 chars, generated at:
#   Google Account → Security → 2-Step Verification → App Passwords)
SMTP_AUTH_PASSWORD=your_gmail_app_password

# Address that will RECEIVE alert emails
SMTP_TO=alert_recipient@example.com

# Gmail address that SENDS alert emails (must match auth_username in alertmanager.yml)
SMTP_FROM=your_sender@gmail.com


# ── OpenSearch / Wazuh ───────────────────────────────────────
# Full URL to your OpenSearch/Wazuh node (include port 9200)
OPENSEARCH_URL=https://[IP_ADDRESS]

# OpenSearch username (default: admin)
OPENSEARCH_USER=admin

# OpenSearch admin password
OPENSEARCH_PASSWORD=your_opensearch_password


# ── FreeIPA (optional — only needed if monitoring a FreeIPA server) ──
FREEIPA_DOMAIN=ipa.lab
FREEIPA_BIND_DN=cn=Directory Manager
FREEIPA_BIND_PW=your_freeipa_password
FREEIPA_HOSTS=master.ipa.lab
CACHE_TTL=60
