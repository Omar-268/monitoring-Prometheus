        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_duration_seconds",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "probe_duration"
        }
      ]
