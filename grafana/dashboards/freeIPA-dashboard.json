                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 3 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Target" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "custom.width", "value": 300 }
            ]
