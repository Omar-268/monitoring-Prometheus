        "sortBy": [{ "desc": false, "displayName": "Status" }]
      },
      "title": "All FreeIPA probe results",
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "instance": "Target",
              "job": "Job",
              "Value #probe_success": "Status",
              "Value #probe_duration": "Duration"
            }
          }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_success",
          "instant": true,
          "legendFormat": "__auto",
